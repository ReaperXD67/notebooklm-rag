# OpenRouter powers both embeddings and grounded answer generation.
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Qdrant Cloud is recommended for the live deployed project.
# Local development also works with: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=atlaslm_chunks

# Optional metadata sent to OpenRouter.
APP_URL=http://localhost:3000
